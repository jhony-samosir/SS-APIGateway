{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Authority": "https://auth.samstore.com",
    "Issuer": "https://auth.samstore.com",
    "Audience": "samstore-api",
    "Algorithm": "RS256",
    "PublicKeyPath": "/run/secrets/jwt_public_key.pem"
  },
  "InternalSignature": {
    "HeaderName": "X-Internal-Signature",
    "SecretKeyEnvVar": "GATEWAY_HMAC_SECRET"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Metadata": {
          "RequiresJwt": "false",
          "BruteForcePolicy": "true"
        },
        "RateLimiterPolicy": "brute-force"
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        },
        "Metadata": {
          "RequiresJwt": "true"
        },
        "RateLimiterPolicy": "global"
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "AuthorizationPolicy": "RequireAuthenticatedUser",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Metadata": {
          "RequiresJwt": "true"
        },
        "RateLimiterPolicy": "global"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://auth-service.internal:8080"
          }
        },
        "HttpClient": {
          "SslProtocols": [ "Tls12", "Tls13" ]
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Path": "/health",
            "Interval": "00:00:10"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        }
      },
      "products-cluster": {
        "Destinations": {
          "products-service": {
            "Address": "http://product-service.internal:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Path": "/health",
            "Interval": "00:00:15"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders-service": {
            "Address": "http://order-service.internal:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Path": "/health",
            "Interval": "00:00:15"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        }
      }
    }
  },
  "RateLimiting": {
    "GlobalPolicy": {
      "PermitLimit": 200,
      "Window": "00:01:00",
      "QueueLimit": 50
    },
    "BruteForcePolicy": {
      "PermitLimit": 5,
      "Window": "00:01:00",
      "QueueLimit": 0
    }
  },
  "Resilience": {
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerSamplingDuration": "00:00:30"
  },
  "OpenTelemetry": {
    "Endpoint": "http://otel-collector:4317",
    "ServiceName": "SS.APIGateway"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.samstore.com",
      "https://admin.samstore.com"
    ]
  }
}
